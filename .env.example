# lonely-world Web UI Configuration
# Copy this file to .env and fill in your values

# ─── Required ────────────────────────────────────────────────────────────────

# Session secret for signed cookies. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
LONELY_WORLD_SESSION_SECRET=

# ─── LLM Provider ────────────────────────────────────────────────────────────
# OpenAI (default)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LONELY_WORLD_MODEL=gpt-4o-mini

# Or use Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LONELY_WORLD_PROVIDER=anthropic

# ─── Optional ───────────────────────────────────────────────────────────────

# Data directory (default: ./local/data)
# LONELY_WORLD_DATA_DIR=./local/data

# Web server port (default: 7860)
# LONELY_WORLD_PORT=7860